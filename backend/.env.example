PORT=3000
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/DriveGo
# Required: use a strong random secret (minimum 16 chars)
JWT_SECRET=

# Firebase Admin (Google Sign-in)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# SePay — https://my.sepay.vn/webhooks
SEPAY_PAYMENT_CODE_PREFIX=DG
SEPAY_WEBHOOK_API_KEY=
SEPAY_WEBHOOK_HMAC_SECRET=
SEPAY_BANK_NAME=
SEPAY_BANK_ACCOUNT=
SEPAY_ACCOUNT_HOLDER=

# Exam rules (optional — fallback to license_classes in DB)
EXAM_PASS_MIN_A1=21
EXAM_PASS_MIN_A2=21
EXAM_PASS_MIN_B1=26
EXAM_PASS_MIN_B2=26
EXAM_DURATION_MINUTES_A1=19
EXAM_DURATION_MINUTES_A2=19
EXAM_DURATION_MINUTES_B1=22
EXAM_DURATION_MINUTES_B2=22
FREE_EXAM_ATTEMPT_LIMIT=10

# Google Gemini — AI Chat (backend only, never expose in frontend)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
